# OPENAI
# ==============================================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ==============================================================
# OLLAMA (local — used ONLY for sensitive queries)
# ==============================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ==============================================================
# MYSQL
# ==============================================================
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=company_db

# ==============================================================
# QDRANT (local Docker)
# ==============================================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=company_docs

# ==============================================================
# SENSITIVE KEYWORDS
# ==============================================================
SENSITIVE_KEYWORDS=salary,password,national_id,address,marital_status,personal,confidential,secret
